{
    "title": "ETL Pipeline Monitoring",
    "tags": [
        "etl",
        "finance"
    ],
    "timezone": "browser",
    "panels": [
        {
            "type": "timeseries",
            "title": "Stock Prices (Close & Rolling Averages)",
            "gridPos": {
                "h": 9,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "postgres",
                "uid": "postgres_etl"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres_etl"
                    },
                    "rawSql": "SELECT trade_date AS \"time\", close_price AS \"value\", symbol AS \"metric\" FROM daily_prices_fact ORDER BY trade_date",
                    "format": "time_series"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "showPoints": "auto",
                        "pointSize": 5,
                        "lineWidth": 2,
                        "scaleDistribution": {
                            "type": "log",
                            "log": 10
                        }
                    }
                }
            }
        },
        {
            "type": "table",
            "title": "ETL Audit Logs - Execution Status",
            "gridPos": {
                "h": 9,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "datasource": {
                "type": "postgres",
                "uid": "postgres_etl"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres_etl"
                    },
                    "rawSql": "SELECT start_time AS \"Start Time\", status AS \"Status\", records_processed AS \"Records\", duration_seconds AS \"Duration (s)\", error_message AS \"Error\" FROM etl_audit_log ORDER BY start_time DESC LIMIT 15",
                    "format": "table"
                }
            ]
        }
    ],
    "schemaVersion": 38,
    "version": 1
}